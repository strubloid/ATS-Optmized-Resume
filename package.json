{
    "name": "curriculum-optimizer",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "node scripts/dev.mjs",
        "dev:api": "npm run dev --workspace @curriculum/api",
        "dev:web": "npm run dev --workspace @curriculum/web",
        "build": "npm run build --workspace @curriculum/web && npm run build --workspace @curriculum/api",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "test": "vitest run",
        "test:unit": "vitest run tests/unit",
        "test:integration": "vitest run tests/integration",
        "test:e2e": "playwright test",
        "ts": "npx tsc --noEmit",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json",
        "typecheck:docker": "docker compose run --rm --build typecheck"
    },
    "dependencies": {
        "@prisma/client": "^6.19.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "docx": "^8.5.0",
        "express": "^4.19.2",
        "express-rate-limit": "^8.5.2",
        "marked": "^14.1.4",
        "pdfkit": "^0.15.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "turndown": "^7.2.4",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@playwright/test": "^1.46.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^22.5.0",
        "@types/pdfkit": "^0.13.5",
        "@types/react": "^18.3.4",
        "@types/react-dom": "^18.3.0",
        "@types/supertest": "^6.0.2",
        "@types/turndown": "^5.0.6",
        "@vitejs/plugin-react": "^6.0.3",
        "jsdom": "^24.1.1",
        "prisma": "^6.19.0",
        "supertest": "^7.0.0",
        "typescript": "^5.5.4",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    }
}
